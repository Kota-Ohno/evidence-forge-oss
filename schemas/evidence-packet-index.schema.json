{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evidence-forge.local/schemas/evidence-packet-index.schema.json",
  "title": "Evidence Forge Evidence packet index",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "kind", "entries", "assurance", "integrity"],
  "properties": {
    "version": { "const": 1 },
    "kind": { "const": "EvidenceForgeEvidencePacketIndex" },
    "entries": {
      "type": "array", "minItems": 1, "maxItems": 100,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["sequence", "packetSha256", "sourceSha256", "sourceByteLength", "candidateId", "evidenceId", "previousEntrySha256", "entrySha256"],
        "properties": {
          "sequence": { "type": "integer", "minimum": 1, "maximum": 100 },
          "packetSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "sourceSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "sourceByteLength": { "type": "integer", "minimum": 0, "maximum": 16777216 },
          "candidateId": { "type": "string", "minLength": 1, "maxLength": 256 },
          "evidenceId": { "type": "string", "minLength": 1, "maxLength": 256 },
          "previousEntrySha256": { "anyOf": [{ "type": "null" }, { "type": "string", "pattern": "^[0-9a-f]{64}$" }] },
          "entrySha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "assurance": {
      "type": "object", "additionalProperties": false, "required": ["timestamp"],
      "properties": { "timestamp": { "const": "not-attested" } }
    },
    "integrity": {
      "type": "object", "additionalProperties": false, "required": ["algorithm", "indexSha256"],
      "properties": {
        "algorithm": { "const": "sha256-jcs" },
        "indexSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
