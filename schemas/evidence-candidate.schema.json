{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evidence-forge.local/schemas/evidence-candidate.schema.json",
  "title": "Evidence Forge candidate envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "id", "snapshot", "selector", "observedAt"],
  "properties": {
    "kind": { "const": "EvidenceCandidate" },
    "id": { "type": "string", "minLength": 1, "maxLength": 256 },
    "snapshot": { "$ref": "#/$defs/sourceSnapshot" },
    "selector": { "$ref": "#/$defs/textQuoteSelector" },
    "citationView": { "$ref": "citation-view.schema.json" },
    "observedAt": { "type": "string", "format": "date-time", "maxLength": 64 }
  },
  "$defs": {
    "sourceSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mediaType", "sha256", "byteLength", "objectPath", "sourceUri", "capturedAt", "availableAt"],
      "properties": {
        "mediaType": { "type": "string", "minLength": 1, "maxLength": 256 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "byteLength": { "type": "integer", "minimum": 0, "maximum": 16777216 },
        "objectPath": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "sourceUri": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "capturedAt": { "type": "string", "format": "date-time", "maxLength": 64 },
        "availableAt": { "type": "string", "format": "date-time", "maxLength": 64 }
      }
    },
    "textQuoteSelector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "exact", "prefix", "suffix"],
      "properties": {
        "type": { "const": "TextQuoteSelector" },
        "exact": { "type": "string", "minLength": 1, "maxLength": 1048576 },
        "prefix": { "type": "string", "maxLength": 32 },
        "suffix": { "type": "string", "maxLength": 32 }
      }
    }
  }
}
