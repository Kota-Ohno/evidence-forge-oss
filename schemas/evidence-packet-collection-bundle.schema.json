{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evidence-forge.local/schemas/evidence-packet-collection-bundle.schema.json",
  "title": "Evidence Forge portable Evidence packet collection bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "kind", "index", "auditReceipt", "packets", "assurance", "integrity"],
  "properties": {
    "version": { "const": 1 },
    "kind": { "const": "EvidenceForgeEvidencePacketCollectionBundle" },
    "index": { "$ref": "evidence-packet-index.schema.json" },
    "auditReceipt": { "$ref": "evidence-packet-collection-audit-receipt.schema.json" },
    "packets": {
      "type": "array", "minItems": 1, "maxItems": 100,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name", "packet"],
        "properties": {
          "name": { "type": "string", "pattern": "^packets/[0-9a-f]{64}\\.json$" },
          "packet": { "$ref": "evidence-packet.schema.json" }
        }
      }
    },
    "assurance": {
      "type": "object", "additionalProperties": false, "required": ["timestamp"],
      "properties": { "timestamp": { "const": "not-attested" } }
    },
    "integrity": {
      "type": "object", "additionalProperties": false, "required": ["algorithm", "bundleSha256"],
      "properties": {
        "algorithm": { "const": "sha256-jcs" },
        "bundleSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
