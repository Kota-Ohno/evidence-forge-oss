{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evidence-forge.local/schemas/evidence-packet-transition-history-audit-verification.schema.json",
  "title": "Evidence Forge Evidence packet transition history audit verification",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "kind", "outcome", "indexSha256", "transitionCount", "initialBundleSha256", "latestBundleSha256", "initialPacketCount", "latestPacketCount", "firstTransitionAuditSha256", "lastTransitionAuditSha256", "auditSha256", "collectionReaudited", "timestampAttested"],
  "properties": {
    "version": { "const": 1 },
    "kind": { "const": "EvidenceForgeEvidencePacketTransitionHistoryAuditVerification" },
    "outcome": { "const": "verified" },
    "indexSha256": { "$ref": "#/$defs/hash" },
    "transitionCount": { "type": "integer", "minimum": 1, "maximum": 99 },
    "initialBundleSha256": { "$ref": "#/$defs/hash" },
    "latestBundleSha256": { "$ref": "#/$defs/hash" },
    "initialPacketCount": { "type": "integer", "minimum": 1, "maximum": 99 },
    "latestPacketCount": { "type": "integer", "minimum": 2, "maximum": 100 },
    "firstTransitionAuditSha256": { "$ref": "#/$defs/hash" },
    "lastTransitionAuditSha256": { "$ref": "#/$defs/hash" },
    "auditSha256": { "$ref": "#/$defs/hash" },
    "collectionReaudited": { "const": false },
    "timestampAttested": { "const": false }
  },
  "$defs": { "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" } }
}
