{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evidence-forge.local/schemas/cli-capabilities.schema.json",
  "title": "Evidence Forge CLI Capabilities",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "kind", "package", "binaries", "errorContract", "schemas", "integrity"],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "properties": {
    "version": { "const": 1 },
    "kind": { "const": "EvidenceForgeCliCapabilities" },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "evidence-forge" },
        "version": { "type": "string", "maxLength": 128, "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$" }
      }
    },
    "binaries": {
      "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true,
      "items": { "type": "string", "maxLength": 128, "pattern": "^evidence-forge(?:-[a-z-]+)?$" }
    },
    "errorContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argument", "value", "schemaPath", "schemaSha256", "maxMessageBytes", "stream", "exitStatus"],
      "properties": {
        "argument": { "const": "--error-format" },
        "value": { "const": "json" },
        "schemaPath": { "const": "schemas/cli-error.schema.json" },
        "schemaSha256": { "$ref": "#/$defs/sha256" },
        "maxMessageBytes": { "const": 4096 },
        "stream": { "const": "stderr" },
        "exitStatus": { "const": "nonzero" }
      }
    },
    "schemas": {
      "type": "array", "minItems": 1, "maxItems": 64,
      "items": {
        "type": "object", "additionalProperties": false, "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "maxLength": 128, "pattern": "^schemas/[a-z-]+\\.schema\\.json$" },
          "sha256": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    "integrity": {
      "type": "object", "additionalProperties": false, "required": ["algorithm", "manifestSha256"],
      "properties": {
        "algorithm": { "const": "sha256-jcs" },
        "manifestSha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
